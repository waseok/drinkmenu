generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Staff {
  id              String               @id @default(cuid())
  name            String
  department      String
  position        String               @default("")
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  orders          Order[]
  groupMembers    StaffGroupMember[]
  sessionTargets  SessionTargetStaff[]

  @@map("staff")
}

model StaffGroup {
  id        String             @id @default(cuid())
  name      String
  sortOrder Int                @default(0)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  members   StaffGroupMember[]

  @@map("staff_groups")
}

model StaffGroupMember {
  id      String     @id @default(cuid())
  groupId String
  staffId String
  group   StaffGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  staff   Staff      @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([groupId, staffId])
  @@map("staff_group_members")
}

model Shop {
  id             String     @id @default(cuid())
  name           String
  address        String     @default("")
  phone          String     @default("")
  category       String     @default("")
  naverPlaceId   String     @default("")
  menuImageUrls  String[]   @default([])
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  menuItems      MenuItem[]
  sessionShops   SessionShop[]

  @@map("shops")
}

model MenuItem {
  id          String   @id @default(cuid())
  shopId      String
  name        String
  price       Int
  category    String   @default("")
  sortOrder   Int      @default(0)
  isAvailable Boolean  @default(true)
  isIce       Boolean  @default(false)
  isHot       Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@map("menu_items")
}

model OrderSession {
  id              String               @id @default(cuid())
  title           String
  date            DateTime
  deadlineTime    String?              // "HH:mm" 형식의 마감 시간 (선택)
  status          SessionStatus        @default(OPEN)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  orders          Order[]
  sessionShops    SessionShop[]
  sessionTargets  SessionTargetStaff[]

  @@map("order_sessions")
}

model SessionTargetStaff {
  id        String       @id @default(cuid())
  sessionId String
  staffId   String
  session   OrderSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  staff     Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([sessionId, staffId])
  @@map("session_target_staff")
}

model SessionShop {
  id        String       @id @default(cuid())
  sessionId String
  shopId    String
  session   OrderSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  shop      Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([sessionId, shopId])
  @@map("session_shops")
}

model Order {
  id         String       @id @default(cuid())
  sessionId  String
  staffId        String
  menuItemId     String?
  customItemName String?
  /** 직접 입력 주문 시, 선택 중이던 세션 매장명(취합 화면에서 업체 구분용) */
  customShopName String?
  quantity       Int          @default(1)
  options        String       @default("")
  price          Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  session        OrderSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  staff          Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  menuItem       MenuItem?    @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@map("orders")
}

enum SessionStatus {
  OPEN
  CLOSED
}
